# AppForge Platform Environment Variables
# Copy this file to .env.local for development

# API Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_USER=appforge_user
DB_PASSWORD=appforge_password
DB_NAME=appforge_db

# Cache (Redis)
REDIS_HOST=redis
REDIS_PORT=6379

# Security
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_EXPIRES_IN=1h

# Rate Limiting
NGINX_RATE_LIMIT=10r/s
